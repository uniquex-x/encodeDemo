{
  "evaluation_config": {
    "description": "音频质量评估配置文件",
    "version": "1.0",
    "default_sample_rate": 16000,
    "supported_formats": ["wav", "ogg", "mp3", "flac", "m4a"],
    
    "quality_thresholds": {
      "excellent": {
        "min_score": 4.5,
        "min_snr": 40,
        "min_correlation": 0.95,
        "description": "优秀 - 几乎无法察觉的差异"
      },
      "good": {
        "min_score": 4.0,
        "min_snr": 30,
        "min_correlation": 0.90,
        "description": "良好 - 轻微差异，可接受的质量"
      },
      "fair": {
        "min_score": 3.0,
        "min_snr": 20,
        "min_correlation": 0.80,
        "description": "一般 - 明显差异，但仍可使用"
      },
      "poor": {
        "min_score": 2.0,
        "min_snr": 10,
        "min_correlation": 0.60,
        "description": "较差 - 显著劣化，质量有限"
      },
      "bad": {
        "min_score": 1.0,
        "min_snr": 0,
        "min_correlation": 0.30,
        "description": "很差 - 严重劣化，不推荐使用"
      }
    },
    
    "evaluation_weights": {
      "snr_weight": 0.4,
      "correlation_weight": 0.3,
      "spectral_weight": 0.3,
      "description": "各指标在综合评分中的权重"
    },
    
    "pesq_config": {
      "target_sample_rates": [8000, 16000],
      "mode": "wb",
      "description": "PESQ评估配置，wb=宽带，nb=窄带"
    },
    
    "output_config": {
      "precision": {
        "score": 3,
        "snr": 2,
        "correlation": 4,
        "mse": 6
      },
      "include_plots": false,
      "save_intermediate_results": false,
      "description": "输出格式配置"
    },
    
    "batch_config": {
      "default_ref_pattern": "*.wav",
      "default_deg_pattern": "*.ogg",
      "max_concurrent": 4,
      "continue_on_error": true,
      "description": "批量处理配置"
    },
    
    "codec_profiles": {
      "vorbis_high": {
        "description": "Vorbis高质量编码",
        "expected_quality_range": [3.5, 4.5],
        "typical_bitrate": "192-320 kbps"
      },
      "vorbis_medium": {
        "description": "Vorbis中等质量编码",
        "expected_quality_range": [3.0, 4.0],
        "typical_bitrate": "128-192 kbps"
      },
      "vorbis_low": {
        "description": "Vorbis低质量编码",
        "expected_quality_range": [2.0, 3.5],
        "typical_bitrate": "64-128 kbps"
      }
    }
  }
}
